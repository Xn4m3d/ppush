# ppush configuration — copy to .env and adjust.
# The app stores only ciphertext; none of these are user-secret material.

# Public URL of the instance (used to build share links and for anti-CSRF).
BASE_URL=http://localhost:3000

# Data directory (SQLite database + encrypted blobs).
DATA_DIR=./data

# Registration controls (empty ALLOWED_EMAIL_DOMAINS = open to anyone).
ALLOWED_EMAIL_DOMAINS=
REQUIRE_APPROVAL=false

# File size limits (MB).
MAX_FILE_SIZE_MB=512
ANON_MAX_FILE_MB=10

# Storage quotas (GB). 0 = disabled.
STORAGE_QUOTA_GB=0
USER_STORAGE_QUOTA_GB=3

# Encrypted text payload cap (KB).
MAX_TEXT_SIZE_KB=1024

# Retention limits (days / views).
USER_MAX_DAYS=30
USER_MAX_VIEWS=50
USER_MAX_FILE_DAYS=30
ANON_MAX_DAYS=7
ANON_MAX_VIEWS=5
ANON_MAX_FILE_DAYS=10
ANON_DEFAULT_DAYS=2
ANON_DEFAULT_VIEWS=1

# Audit log.
LOG_IPS=true
DATA_RETENTION_DAYS=365

# Session lifetime (days).
SESSION_DAYS=14

# Cloudflare Turnstile (anti-bot at registration). Empty = disabled.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
