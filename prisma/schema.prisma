generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String?   // null = account without a password (passkey only)
  role         String    @default("USER") // USER | ADMIN
  active       Boolean   @default(true)
  approvedAt   DateTime? // null + !active = account awaiting approval
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  // 2FA TOTP (RFC 6238)
  totpSecret    String? // base32 — active only if totpEnabledAt is non-null
  totpEnabledAt DateTime?
  totpLastStep  Int?    // anti-replay: last accepted time step

  // Default preferences for new pushes
  defaultDays              Int     @default(7)
  defaultViews             Int     @default(5)
  defaultRetrievalStep     Boolean @default(true)
  defaultDeletableByViewer Boolean @default(true)
  // Auto-redirect of EXTERNAL URL pushes (opt-in; off by default, security).
  // Same-origin URLs (e.g. /reset-password) always open automatically.
  autoOpenUrls             Boolean @default(false)
  // Preferred theme: "auto" (day mecha / night midnight) | "midnight" | "mecha"
  // | null (= follows the cookie / auto default).
  theme                    String?

  sessions       Session[]
  pushes         Push[]
  apiTokens      ApiToken[]
  credentials    Credential[]
  passwordResets PasswordReset[]
}

// Passkey (WebAuthn / FIDO2)
model Credential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique // base64url
  publicKey    Bytes // COSE public key
  counter      Int       @default(0)
  transports   String? // JSON: ["internal","hybrid",…]
  name         String? // label given by the user
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  ip        String?
  userAgent String?

  @@index([userId])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model Push {
  id     String @id @default(cuid())
  slug   String  @unique
  kind   String // PASSWORD | TEXT | FILE | URL
  userId String? // null = anonymous push (created without an account)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Client-side encrypted payload (AES-256-GCM, key never sent to the server).
  // Small payloads in the DB; files on disk (blobPath).
  ciphertext     Bytes?
  blobPath       String?
  fileSize       Int?
  payloadDeleted Boolean @default(false)

  passphraseHash String?

  expireAfterViews   Int
  expireAfterMinutes Int
  views              Int     @default(0)
  retrievalStep     Boolean @default(true)
  deletableByViewer Boolean @default(true)

  // Creator's private note (internal reference, never shown to the recipient)
  note String?

  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  expiredAt    DateTime?
  expireReason String? // VIEWS | TIME | OWNER | VIEWER | ADMIN

  events AuditEvent[]

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  pushId    String
  push      Push     @relation(fields: [pushId], references: [id], onDelete: Cascade)
  kind      String // CREATED | VIEW | FAILED_PASSPHRASE | EXPIRED | OWNER_DELETE | VIEWER_DELETE
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([pushId, createdAt])
}

// Single-use password reset, initiated by an admin (no recovery email). The
// clear-text token only exists long enough to be relayed through a ppush push
// (E2E-encrypted); the database stores only its SHA-256 hash. Single-use
// (`usedAt`) + short expiry.
model PasswordReset {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  createdById String? // initiating admin (denormalized via AdminAudit for the duration)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  usedAt      DateTime?

  @@index([userId])
}

// Administration action log (traceability / GDPR accountability: admins access
// personal metadata). Actor + email denormalized to survive deletion of the
// admin account. Subject to the same retention as the other logs (anonymization
// / purge by the sweeper).
model AdminAudit {
  id          String   @id @default(cuid())
  actorId     String? // admin id (null if the account was deleted since)
  actorEmail  String // denormalized (durable)
  action      String // USER_DISABLE | USER_ENABLE | USER_ROLE | USER_EDIT | USER_RESET_PW | USER_RESET_2FA | USER_LOGOUT | USER_DELETE | PUSH_TAKEDOWN | RECOVERY_HANDLE | RECOVERY_REJECT
  targetType  String // USER | PUSH
  targetId    String?
  targetLabel String? // email / slug (denormalized)
  details     String? // optional JSON
  ip          String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Access-recovery request (no automatic reset email). The locked-out user
// describes their proof of identity; an admin verifies it, then generates a
// reset link (delivered out-of-band). Shown in the admin area (Requests tab).
model RecoveryRequest {
  id        String    @id @default(cuid())
  email     String
  message   String // what the user describes (proof, context)
  contact   String? // alternative contact channel (optional)
  status    String    @default("PENDING") // PENDING | HANDLED | REJECTED
  ip        String?
  userAgent String?
  adminNote String?
  createdAt DateTime  @default(now())
  handledAt DateTime?
  handledBy String? // email of the admin who handled it

  @@index([status, createdAt])
}

// Security tips shown on the site (sign-up panel), editable from the admin.
// Bilingual (en + fr). Seeded on first access from the bundled defaults
// (messages/*.json → tips.list). `sortOrder` = display order.
model Tip {
  id        String   @id @default(cuid())
  en        String
  fr        String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([active, sortOrder])
}

// ANONYMOUS daily aggregates (counters only, no personal data) — incremented on
// the fly. Survive the purge of raw data (~12 months) → reliable multi-year,
// GDPR-compliant history. Key = UTC day "YYYY-MM-DD".
model DailyStat {
  date       String @id
  pushes     Int    @default(0)
  pushesAnon Int    @default(0)
  views      Int    @default(0)
  signups    Int    @default(0)
}
